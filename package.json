{
  "name": "honox-valtown-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build --mode node",
    "build:wintertc": "vite build --mode client && vite build --mode wintertc",
    "build:deno": "vite build --mode client && vite build --mode deno",
    "preview": "node --run build && node dist/index.js",
    "preview:bun": "bun run build && bun dist/index.js",
    "preview:deno": "deno run build && deno serve -A dist/index.js",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/react-renderer": "^1.0.1",
    "hono": "^4.12.25",
    "honox": "^0.1.56",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/redact": "^0.0.12",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "magic-string": "^0.30.21",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "unenv": "2.0.0-rc.24",
    "vite": "^8.0.16"
  },
  "imports": {
    "#app/*": [
      "./app/*"
    ]
  },
  "prettier": {
    "semi": false
  }
}
