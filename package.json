{
  "name": "honox-valtown-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build --mode node",
    "build:wintertc": "vite build --mode client && vite build --mode wintertc",
    "build:deno": "vite build --mode client && vite build --mode deno",
    "preview": "node --run build && node dist/index.js",
    "preview:bun": "bun run build && bun dist/index.js",
    "preview:deno": "deno run build && deno serve -A dist/index.js",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.23",
    "honox": "^0.1.56",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "magic-string": "^0.30.21",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "unenv": "2.0.0-rc.24",
    "vite": "^8.0.16"
  },
  "overrides": {
    "react": "link:overrides/react",
    "react-dom": "link:overrides/react-dom"
  },
  "pnpm": {
    "overrides": {
      "react": "link:overrides/react",
      "react-dom": "link:overrides/react-dom"
    }
  },
  "imports": {
    "#app/*": [
      "./app/*"
    ]
  },
  "prettier": {
    "semi": false
  }
}
